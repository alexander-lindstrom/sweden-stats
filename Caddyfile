datamedmera.se {
    handle /geoserver/web/* {
        respond 403
    }

    # More specific rule first — /api/kolada/* proxied to Kolada v3 (no CORS headers on their end)
    handle_path /api/kolada/* {
        rewrite * /v3{path}
        reverse_proxy https://api.kolada.se
    }

    handle /api/* {
        reverse_proxy backend:3001
    }

    handle /geoserver/* {
        reverse_proxy geoserver:8080
    }

    handle /assets/* {
        root * /var/www/html
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    handle {
        root * /var/www/html
        try_files {path} /index.html
        file_server
    }
}
